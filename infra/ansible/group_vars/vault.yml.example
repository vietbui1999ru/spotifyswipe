# SpotiSwipe - Ansible Vault Secrets Template
# Copy to vault.yml and encrypt with: ansible-vault encrypt group_vars/vault.yml
#
# Generate vault password file: openssl rand -base64 32 > .vault_password
# Never commit .vault_password or the encrypted vault.yml to git.

vault_db_password: "CHANGE_ME_secure_database_password"
vault_auth_secret: "CHANGE_ME_random_auth_secret_32_chars"
vault_auth_spotify_id: "CHANGE_ME_spotify_client_id"
vault_auth_spotify_secret: "CHANGE_ME_spotify_client_secret"
vault_lastfm_api_key: "CHANGE_ME_lastfm_api_key"
vault_lastfm_api_secret: "CHANGE_ME_lastfm_shared_secret"
